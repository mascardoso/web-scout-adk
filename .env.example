# Local Environment Variables Template for web-scout-adk
# Copy this file to '.env' and insert your private API keys. Do NOT commit the '.env' file.

# Google AI Studio Gemini API Key
# Generate one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Developer Portal API Key
# Generate one at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
